# Google Service Account email (Credentials JSON -> client_email)
GOOGLE_CLIENT_EMAIL=

# Google Service Account private key (Credentials JSON -> private_key)
# Importante: en Vercel pegar el valor completo respetando saltos de línea.
# El backend lo transforma usando replace(/\\n/g, "\n").
GOOGLE_PRIVATE_KEY=

# Spreadsheet ID de Google Sheets (la parte entre /d/ y /edit en la URL)
GOOGLE_SHEET_ID=
